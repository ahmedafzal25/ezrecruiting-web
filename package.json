{
  "name": "procruit---recruitment-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server,ai,proctor,ollama -c cyan,green,magenta,yellow,blue \"npm run client\" \"npm run server\" \"npm run ai\" \"npm run proctor\" \"npm run ollama\"",
    "client": "vite",
    "server": "npm run dev --prefix server",
    "ai": "cd ai-service && .\\venv\\Scripts\\python -m uvicorn main:app --reload --port 8000",
    "proctor": "cd proctoring-service && .\\venv\\Scripts\\python -m uvicorn main:app --reload --port 8001",
    "ollama": "cmd /c \"ollama serve 2>nul || echo [Ollama] Already running or not installed - skipping\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}